{
  "name": "spareparts-hub-server",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "ts-node -r dotenv/config src/db/migrate.ts",
    "promote-admin": "ts-node -r dotenv/config src/scripts/promote-admin.ts",
    "create-admin": "ts-node -r dotenv/config src/scripts/create-admin.ts",
    "create-test-users": "ts-node -r dotenv/config src/scripts/create-test-users.ts",
    "send-test-push": "ts-node -r dotenv/config src/scripts/send-test-push.ts",
    "generate-password-hash": "ts-node -r dotenv/config src/scripts/generate-password-hash.ts",
    "geocode:legacy": "ts-node -r dotenv/config src/scripts/geocodeLegacyLocations.ts"
  },
  "dependencies": {
    "@googlemaps/polyline-codec": "^1.0.28",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.6.0",
    "nodemailer": "^6.9.15",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.11.0",
    "pino-pretty": "^11.3.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0"
  }
}
